{
  "manifest_version": 3,
  "name": "Smart Shopping & Adidas Price Checker",
  "version": "1.1",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
"content_scripts": [
  {
    "matches": [
      "*://*.super-pharm.co.il/*",
      "*://*.365mashbir.co.il/*",
      "*://*.ksp.co.il/*",
      "*://*.shufersal.co.il/*"
    ],
    "js": ["config.js", "content.js"]
  }
]
}