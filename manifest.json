{
  "manifest_version": 3,
  "name": "Smart Shopping & Adidas Price Checker",
  "version": "1.1",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
"content_scripts": [
    {
      "matches": [
        "*://*.adidas.co.il/*",
        "*://*.terminalx.com/*",
        "*://*.super-pharm.co.il/*"
      ],
      "js": [ "config.js", "userTracker.js", "content.js" ]
    }
  ]
}